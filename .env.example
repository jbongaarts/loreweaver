# Path to the SQLite database file for the active campaign
LOREWEAVER_DB_PATH=./campaigns/dev.db
# Claude model id used by the DM agent
LOREWEAVER_MODEL=claude-opus-4-7
# Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=

# --- Model profiles (provider-neutral) ---
# Loreweaver routes tasks to capability-based profiles, each mapped to a
# provider adapter (neutral id) + model. Defaults are used when unset.
# Profiles: PREMIUM_DM, STATE_EXTRACTOR, SUMMARIZER, RULES_ADJUDICATOR,
#           MEMORY_RECONCILER, EMBEDDING_PROVIDER, ECONOMY_OR_EXPERIMENTAL
# Provider ids: anthropic, openai, bedrock, gemini, openrouter, local
# Override per profile (example shown for the primary DM profile):
# LOREWEAVER_PROFILE_PREMIUM_DM_PROVIDER=anthropic
# LOREWEAVER_PROFILE_PREMIUM_DM_MODEL=claude-opus-4-7
# Note: premium_dm enforces a capability FLOOR (Opus 4.6+/GPT-5.5-class or
# future equivalent); economy models must not silently serve the primary DM.
