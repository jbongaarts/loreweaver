
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
# Passive JSONL exports: data lives on the refs/dolt/data git ref
# (sync via `bd dolt push`/`pull`), not committed to source branches.
.beads/issues.jsonl
.beads/interactions.jsonl

# Node / TypeScript build artifacts
node_modules/
dist/
*.tsbuildinfo
.env

# Windows/Cygwin crash dumps
*.stackdump

# bd-managed git worktrees (local, per-machine)
.worktrees/

# Claude Code local/personal settings (shared settings.json is tracked)
.claude/settings.local.json

# Importer scratch output: regenerated each run, not the canonical pack
# location. See packages/core/scripts/importers/dnd5e-srd-5.1/README.md.
packages/core/scripts/importers/*/.generated/

# Vendored licensed source artifacts: approved open-licensed PDFs (e.g. the D&D
# SRD 5.1 under CC-BY-4.0) ARE committed in-repo per ADR 0007 so importer
# coverage and audit tooling can run against a pinned authoritative source on
# every clone and in CI. Any non-PDF scratch files in those directories stay
# ignored so contributors can't accidentally commit extracted text or local
# regeneration output. See packages/core/sources/<system>/manifest.json for the
# pinned URL/version/hash and packages/core/sources/<system>/README.md for the
# placement policy.
packages/core/sources/*/*.txt
packages/core/sources/*/*.html
packages/core/sources/*/.cache/
