{
  "name": "eshyra",
  "description": "Text-first persistent AI Dungeon Master for long-running fantasy campaigns.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbongaarts/eshyra.git"
  },
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build --force && tsc -p packages/core/scripts/tsconfig.json",
    "pretest": "tsc --build",
    "test": "vitest run",
    "smoke:cli-install": "node scripts/smoke-cli-install.mjs",
    "import:dnd5e-srd": "tsx packages/core/scripts/importers/dnd5e-srd-5.1/cli.ts",
    "verify:dnd5e-srd-pack": "tsx packages/core/scripts/verify-dnd5e-srd-pack/cli.ts",
    "generate:dnd5e-srd-creature-names": "tsx packages/core/scripts/generate-creature-name-baseline/cli.ts",
    "audit:rules-pack": "tsx packages/core/scripts/rules-pack-audit/cli.ts audit",
    "diff:rules-pack": "tsx packages/core/scripts/rules-pack-audit/cli.ts diff",
    "audit-bundle:dnd5e-srd": "tsx packages/core/scripts/create-dnd5e-srd-audit-bundle/cli.ts",
    "agent:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent-preflight-main.ps1",
    "verify:worktree": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-current-worktree.ps1",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "check:hidden-unicode": "node scripts/check-hidden-unicode.mjs",
    "check": "npm run check:hidden-unicode && biome ci ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
