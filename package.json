{
  "name": "loreweaver",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build --force",
    "pretest": "tsc --build",
    "test": "vitest run",
    "smoke:cli-install": "node scripts/smoke-cli-install.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
