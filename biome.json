{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "warn",
        "noUnusedTemplateLiteral": "warn",
        "useImportType": "warn",
        "useTemplate": "warn"
      },
      "performance": {
        "noDelete": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn"
      },
      "suspicious": {
        "noAssignInExpressions": "warn",
        "noEmptyInterface": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.tsbuildinfo",
      "!**/package-lock.json",
      "!**/packages/core/data",
      "!**/.beads",
      "!**/.worktrees",
      "!**/coverage"
    ]
  }
}
