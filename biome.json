{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "warn",
        "noUnusedTemplateLiteral": "warn",
        "useImportType": "warn",
        "useTemplate": "warn"
      },
      "performance": {
        "noDelete": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn"
      },
      "suspicious": {
        "noAssignInExpressions": "warn",
        "noEmptyInterface": "warn"
      }
    }
  },
  "files": {
    "ignore": [
      "dist/",
      "node_modules/",
      "**/*.tsbuildinfo",
      "package-lock.json",
      "packages/core/data/",
      ".beads/",
      "coverage/"
    ]
  }
}
