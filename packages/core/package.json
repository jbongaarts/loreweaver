{
  "name": "@eshyra/core",
  "version": "0.0.0",
  "description": "UI-agnostic Eshyra campaign engine, persistence, rules, and model orchestration.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist",
    "data"
  ],
